{
  "name": "eidos",
  "version": "1.0.0",
  "description": "A native Windows command bar for finding, opening, and creating files.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
